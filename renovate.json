{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/gradle/images\\.versions\\.toml$/"],
      "matchStrings": [
        "\"(?<depName>[^\"@:]+(?:/[^\"@:]+)*):(?<currentValue>[^\"@]+)@(?<currentDigest>sha256:[a-f0-9]+)\""
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "EclipseLink v2",
      "matchPackageNames": ["org.eclipse.persistence:eclipselink"],
      "matchCurrentValue": "/^2\\./",
      "allowedVersions": "<3"
    },
    {
      "description": "EclipseLink v3",
      "matchPackageNames": ["org.eclipse.persistence:eclipselink"],
      "matchCurrentValue": "/^3\\./",
      "allowedVersions": "<4"
    },
    {
      "description": "EclipseLink v4",
      "matchPackageNames": ["org.eclipse.persistence:eclipselink"],
      "matchCurrentValue": "/^4\\./",
      "allowedVersions": "<5"
    },
    {
      "description": "Hibernate v6",
      "matchPackageNames": ["org.hibernate.orm:hibernate-core"],
      "matchCurrentValue": "/^6\\./",
      "allowedVersions": "<7"
    },
    {
      "description": "jOOQ v3.0.0 — intentional minimum-version pin, never update",
      "matchPackageNames": ["org.jooq:jooq"],
      "matchCurrentValue": "3.0.0",
      "enabled": false
    },
    {
      "description": "jOOQ v3.14 — last Java 8 version",
      "matchPackageNames": ["org.jooq:jooq"],
      "matchCurrentValue": "/^3\\.14\\./",
      "allowedVersions": "<3.15"
    },
    {
      "description": "jOOQ v3.16 — last Java 11 version",
      "matchPackageNames": ["org.jooq:jooq"],
      "matchCurrentValue": "/^3\\.16\\./",
      "allowedVersions": "<3.17"
    },
    {
      "description": "jOOQ v3.19 — last Java 17 version",
      "matchPackageNames": ["org.jooq:jooq"],
      "matchCurrentValue": "/^3\\.19\\./",
      "allowedVersions": "<3.20"
    },
    {
      "description": "Spring v5",
      "matchPackageNames": ["org.springframework:*"],
      "matchCurrentValue": "/^5\\./",
      "allowedVersions": "<6"
    },
    {
      "description": "Weld SE v3",
      "matchPackageNames": ["org.jboss.weld.se:weld-se-core"],
      "matchCurrentValue": "/^3\\./",
      "allowedVersions": "<4"
    },
    {
      "description": "Weld SE v5",
      "matchPackageNames": ["org.jboss.weld.se:weld-se-core"],
      "matchCurrentValue": "/^5\\./",
      "allowedVersions": "<6"
    },
    {
      "description": "HikariCP v4 — compile target; pinned for Java 8 compatibility",
      "matchPackageNames": ["com.zaxxer:HikariCP"],
      "matchCurrentValue": "/^4\\./",
      "allowedVersions": "<5"
    },
    {
      "description": "HikariCP v5",
      "matchPackageNames": ["com.zaxxer:HikariCP"],
      "matchCurrentValue": "/^5\\./",
      "allowedVersions": "<6"
    },
    {
      "description": "HikariCP v6",
      "matchPackageNames": ["com.zaxxer:HikariCP"],
      "matchCurrentValue": "/^6\\./",
      "allowedVersions": "<7"
    },
    {
      "description": "HikariCP v7",
      "matchPackageNames": ["com.zaxxer:HikariCP"],
      "matchCurrentValue": "/^7\\./",
      "allowedVersions": "<8"
    },
    {
      "description": "Jetty 9",
      "matchPackageNames": ["org.eclipse.jetty:*", "org.eclipse.jetty.ee10:*"],
      "matchCurrentValue": "/^9\\./",
      "allowedVersions": "<10"
    },
    {
      "description": "Selenium groovy3 — capped at 4.34.x for Geb 6 compatibility",
      "matchPackageNames": ["org.seleniumhq.selenium:*"],
      "matchCurrentValue": "/^4\\.34\\./",
      "allowedVersions": "<4.35.0"
    },
    {
      "description": "Block major updates for cross-version-tested dependencies",
      "matchPackageNames": [
        "com.h2database:*",
        "com.puppycrawl.tools:checkstyle",
        "com.zaxxer:HikariCP",
        "io.ratpack:*",
        "jakarta.*:*",
        "javax:javaee-api",
        "org.apache.groovy:*",
        "org.codehaus.groovy:*",
        "org.gebish:*",
        "org.hibernate:*",
        "org.junit.jupiter:*",
        "org.junit.platform:*",
        "org.seleniumhq.selenium:*",
        "org.spockframework:*",
        "org.springframework:*"
      ],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "jakarta.servlet:jakarta.servlet-api — disabled entirely",
      "matchPackageNames": ["jakarta.servlet:jakarta.servlet-api"],
      "enabled": false
    },
    {
      "description": "javax.servlet:servlet-api — pin below 2.4",
      "matchPackageNames": ["javax.servlet:servlet-api"],
      "allowedVersions": "<2.4"
    },
    {
      "description": "Logback — pin below 1.4 for slf4j 1.x compatibility",
      "matchPackageNames": ["ch.qos.logback:*"],
      "allowedVersions": "<1.4"
    },
    {
      "description": "Spock — keep groovy3 entries on the -groovy-3.0 classifier",
      "matchPackageNames": ["org.spockframework:*"],
      "matchCurrentValue": "/-groovy-3\\.0$/",
      "allowedVersions": "/-groovy-3\\.0$/"
    },
    {
      "description": "Spock — keep groovy4 entries on the -groovy-4.0 classifier",
      "matchPackageNames": ["org.spockframework:*"],
      "matchCurrentValue": "/-groovy-4\\.0$/",
      "allowedVersions": "/-groovy-4\\.0$/"
    },
    {
      "description": "wildfly10 scenario image — pin to major 10",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["jboss/wildfly"],
      "allowedVersions": "<11"
    },
    {
      "description": "wildfly27 scenario image — pin to major 27",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["quay.io/wildfly/wildfly"],
      "allowedVersions": "<28"
    },
    {
      "description": "glassfish4 scenario image — pin to major 4",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["glassfish"],
      "allowedVersions": "<5"
    },
    {
      "description": "glassfish7 scenario image — pin to 7.0.x; 7.1 raises JDK floor to 17 and we test against JDK 11",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/eclipse-ee4j/glassfish"],
      "allowedVersions": "<7.1"
    },
    {
      "description": "jetty9 scenario image — pin to major 9",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["jetty"],
      "matchCurrentValue": "/^9/",
      "allowedVersions": "<10"
    },
    {
      "description": "jetty12 scenario image — pin to major 12",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["jetty"],
      "matchCurrentValue": "/^12\\./",
      "allowedVersions": "<13"
    }
  ]
}
